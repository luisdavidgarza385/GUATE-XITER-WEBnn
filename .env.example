# =============================================
# 🔐 VARIABLES DE ENTORNO - GUATE XITER PRO
# =============================================
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el .env real a Git (ya está en .gitignore).

# 🔥 Firebase Realtime Database
FIREBASE_DB_URL=https://tu-proyecto-default-rtdb.firebaseio.com
FIREBASE_DB_SECRET=tu_database_secret_aqui

# 🔐 Secreto para firmar tokens JWT (genera uno aleatorio en producción)
JWT_SECRET=cambia_esto_por_algo_aleatorio_largo_y_seguro

# 👑 (Opcional) Cuenta de servicio - alternativa moderna al DB_SECRET legacy
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
